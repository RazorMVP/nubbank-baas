# DO NOT commit a populated copy.
# Replace every <CHANGE_ME> before bringing the stack up.
#
# Copy to .env, fill in values, then `docker compose up --build`.
# All secret values are required — the engine fails fast on missing env vars.

# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_DB=nubbank_baas
POSTGRES_USER=baas
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_PORT=5432

# ─── BaaS engine (port + secrets) ─────────────────────────────────────────────
BAAS_ENGINE_PORT=8080
# Must be ≥32 chars. Used by PartnerJwtService for HMAC-SHA256.
# Generate with: openssl rand -base64 48
JWT_SECRET=<CHANGE_ME>
# Used by FieldEncryptor (PII at rest) and TwoFactorService (OTP HMAC).
# Hashed to SHA-256 internally so any length works, but use ≥32 chars of high entropy.
# Generate with: openssl rand -base64 48
ENCRYPTION_KEY=<CHANGE_ME>

# ─── Inter-service HMAC (engine ↔ ncube) ──────────────────────────────────────
# Shared by both baas-engine (signs outbound calls via InternalServiceClient) and
# baas-ncube (validates inbound via InternalServiceAuthFilter). Must be ≥32 chars
# or both services refuse to start. Rotation requires a rolling restart of both.
# Generate with: openssl rand -base64 48
INTERNAL_SERVICE_SECRET=<CHANGE_ME>

# ─── BaaS ncube (CBN Open Banking / NIBSS NPS adapter) ────────────────────────
BAAS_NCUBE_PORT=8082
# NPS_ENDPOINT was formerly NIBSS_NPS_BASE_URL — update any local copies.
# Override with a real NIBSS NPS sandbox/prod URL when going live (Phase 2).
NPS_ENDPOINT=https://nps-sandbox.nibss-plc.com.ng
NPS_LIVE=false
NPS_MEMBER_ID=999058
NPS_BICFI=999058
NPS_INSTITUTION_NAME=NubBank BaaS
NPS_SIGNING_ENABLED=false
NPS_ENCRYPTION_ENABLED=false

# ─── Spring profile ───────────────────────────────────────────────────────────
# 'local' = development; 'production' = real deployment (ComplianceService stub
# refuses to start under 'production' unless app.compliance.allow-stub=true).
SPRING_PROFILES_ACTIVE=local
