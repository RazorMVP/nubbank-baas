# Copy to .env, fill in values, then `docker compose up --build`.
# All values are required — there are NO defaults; the engine fails fast on missing env vars.

# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_DB=nubbank_baas
POSTGRES_USER=baas
POSTGRES_PASSWORD=replace-me-with-a-strong-password
POSTGRES_PORT=5432

# ─── BaaS engine (port + secrets) ─────────────────────────────────────────────
BAAS_ENGINE_PORT=8080
# Must be ≥32 chars. Used by PartnerJwtService for HMAC-SHA256.
JWT_SECRET=replace-me-with-a-32-char-or-longer-random-string
# Used by FieldEncryptor (PII at rest) and TwoFactorService (OTP HMAC).
# Hashed to SHA-256 internally so any length works, but use ≥32 chars of high entropy.
ENCRYPTION_KEY=replace-me-with-a-32-char-or-longer-random-string

# ─── BaaS ncube (CBN Open Banking adapter) ────────────────────────────────────
BAAS_NCUBE_PORT=8081
# Override with a real NIBSS NPS sandbox/prod URL when going live (Phase 2).
NIBSS_NPS_BASE_URL=http://stub.local

# ─── Spring profile ───────────────────────────────────────────────────────────
# 'local' = development; 'production' = real deployment (ComplianceService stub
# refuses to start under 'production' unless app.compliance.allow-stub=true).
SPRING_PROFILES_ACTIVE=local
