# API
# Leave VITE_API_BASE_URL empty to run against a LOCAL baas-engine via the Vite
# dev proxy (browser -> Vite same-origin -> /baas/** forwarded to the engine),
# which avoids cross-origin CORS. Set an absolute URL to call a remote API
# directly. See docs/backoffice-local-dev.md.
VITE_API_BASE_URL=
# Origin the dev proxy forwards /baas/** to (used only when VITE_API_BASE_URL is empty).
VITE_ENGINE_ORIGIN=http://localhost:8080
VITE_OPENAPI_URL=http://localhost:8080/v3/api-docs

# Dev auth (local/CI/e2e). Set VITE_DEV_AUTH=false for PKCE.
VITE_DEV_AUTH=true
# 'dev-token' is a placeholder accepted only by the frontend dev-auth provider.
# To exercise a LOCAL engine, set this to a real partner JWT from
# POST /baas/v1/auth/register (the engine has no dev-token bypass).
VITE_DEV_TOKEN=dev-token
VITE_DEV_AUTHORITIES=READ_CUSTOMER,CREATE_CUSTOMER,UPDATE_CUSTOMER,READ_ACCOUNT,CREATE_ACCOUNT,UPDATE_ACCOUNT,DEPOSIT,WITHDRAW,READ_LOAN,CREATE_LOAN,APPROVE_LOAN,DISBURSE_LOAN,INITIATE_PAYMENT,RUN_REPORT

# PKCE (prod)
VITE_OIDC_AUTHORITY=
VITE_OIDC_CLIENT_ID=baas-backoffice
VITE_OIDC_REDIRECT_URI=http://localhost:3001/auth/callback
